{
  "manifest_version": 3,
  "name": "Oji-San - AI Dojo Focus Master",
  "version": "1.0.0",
  "description": "The strict, wise, 36th Chamber AI Master that beats distraction out of you.",
  "icons": {
    "16": "public/icon16.png",
    "32": "public/icon32.png",
    "48": "public/icon48.png",
    "128": "public/icon128.png"
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "index.html",
    "default_title": "Oji-San Dojo",
    "default_icon": {
      "16": "public/icon16.png",
      "32": "public/icon32.png",
      "48": "public/icon48.png",
      "128": "public/icon128.png"
    }
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.tsx-loader-Byj8Esxb.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/createLucideIcon-fXvbFTNE.js",
        "assets/oji-san-states-DeIkGr94.js",
        "assets/content.tsx-CoZgkDJ7.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
